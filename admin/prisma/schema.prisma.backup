generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ---------- USER MODEL (For Authentication) ----------
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  documents           Document[]
  checklistItems      ChecklistItem[]
  complianceActivities ComplianceActivity[]
  
  // For NextAuth.js
  accounts            Account[]
  sessions            Session[]
}

/// ---------- AUTH MODELS (For NextAuth.js) ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// ---------- NGO CORE ----------
model NGO {
  id               String   @id @default(cuid())
  name             String
  regNo            String?
  createdAt        DateTime @default(now())
  emailFrom        String?
  receiptSettings  Json?
  receiptFYKey     String?
  receiptFYCounter Int?
  smtpHost         String?
  smtpPass         String?
  smtpPort         Int?
  smtpUser         String?

  beneficiaries        Beneficiary[]
  branches             Branch[]
  campaigns            Campaign[]
  communications       CommunicationThread[]
  donations            Donation[]
  donors               Donor[]
  reports              SavedReport[]
  volunteers           Volunteer[]
  VolunteerReport      VolunteerReport[]
  VolunteerActivity    VolunteerActivity[]
  VolunteerLog         VolunteerLog[]
  VolunteerBadge       VolunteerBadge[]
  VolunteerAchievement VolunteerAchievement[]
  Trustee              Trustee[]
  BoardActivity        BoardActivity[]
  passwordEntries      PasswordEntry[]
  pledges              Pledge[]
  reminders            Reminder[]
  events               Event[]
}

/// ---------- BRANCH ----------
model Branch {
  id            String   @id @default(cuid())
  ngoId         String
  name          String
  status        String   @default("active")
  manager       String
  phone         String
  email         String
  address       String
  staff         Int      @default(0)
  beneficiaries Int      @default(0)
  funding       String   @default("$0")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  beneficiaryMembers Beneficiary[]
  ngo                NGO           @relation(fields: [ngoId], references: [id])
  volunteerMembers   Volunteer[]

  @@index([ngoId])
}

/// ---------- BENEFICIARY ----------
model Beneficiary {
  id         String            @id @default(cuid())
  ngoId      String
  branchId   String?
  name       String
  contact    String?
  email      String?
  address    String?
  dob        DateTime?
  gender     String?
  occupation String?
  income     String?
  avatar     String?
  household  String?
  assistance String[] @default([])
  lastAssistance DateTime?
  status     BeneficiaryStatus @default(NEW)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])
  ngo    NGO     @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
  @@index([branchId])
}

/// ---------- DONOR & DONATION ----------
model Donor {
  id            String    @id @default(cuid())
  ngoId         String
  name          String
  email         String?
  phone         String?
  address       String?
  notes         String?
  avatar        String?
  type          String    @default("individual")
  status        String    @default("New")
  total         Decimal   @default(0) @db.Decimal(12, 2)
  donations     Int       @default(0)
  createdAt     DateTime  @default(now())
  lastDonatedAt DateTime?
  updatedAt     DateTime  @updatedAt
  pan           String?
  segment       String?
  tags          Json?

  donationRecords Donation[]
  ngo             NGO        @relation(fields: [ngoId], references: [id])

  @@unique([ngoId, email], map: "donor_email_per_ngo_unique")
  @@unique([ngoId, phone], map: "donor_phone_per_ngo_unique")
  @@index([ngoId])
}

/// ---------- CAMPAIGN ----------
model Campaign {
  id         String         @id @default(cuid())
  title      String
  summary    String?
  status     CampaignStatus
  location   String?
  startDate  DateTime?
  endDate    DateTime?
  lead       String?
  raised     Int            @default(0)
  goal       Int            @default(0)
  image      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  ngoId      String
  category   String?
  slug       String?
  isArchived Boolean?       @default(false)
  createdby  String?
  updatedby  String?

  ngo       NGO        @relation(fields: [ngoId], references: [id])
  donations Donation[]

  @@index([ngoId])
}

model Donation {
  id             String         @id @default(cuid())
  ngoId          String
  donorId        String
  campaignId     String?
  amount         Decimal        @db.Decimal(12, 2)
  donatedAt      DateTime       @default(now())
  status         DonationStatus @default(CONFIRMED)
  note           String?
  createdAt      DateTime       @default(now())
  currency       String         @default("INR")
  fxRate         Decimal?       @db.Decimal(12, 6)
  fcra           Boolean?
  paymentMode    PaymentMode?
  utr            String?
  bankName       String?
  cardLast4      String?
  chequeNo       String?
  gateway        String?
  gatewayRef     String?
  giftInMemoryOf String?
  giftInHonourOf String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  receiptNumber  String?
  receiptFileUrl String?
  updatedAt      DateTime       @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id])
  donor    Donor     @relation(fields: [donorId], references: [id])
  ngo      NGO       @relation(fields: [ngoId], references: [id])

  @@index([gateway, gatewayRef])
  @@index([ngoId])
  @@index([donorId])
  @@index([campaignId])
}

/// ---------- EVENT ----------
model Event {
  id           String      @id @default(cuid())
  ngoId        String?
  name         String
  location     String
  type         EventType
  status       EventStatus @default(UPCOMING)
  participants String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  budget       Int?
  dateISO      DateTime
  description  String
  endTime      String
  expected     Int?
  img          String?
  startTime    String
  volunteers   Int?
  organizer    String?

  participantsList  EventParticipant[]
  VolunteerActivity VolunteerActivity[]
  ngo               NGO?               @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
}

/// ---------- EVENT PARTICIPANT ----------
model EventParticipant {
  id          String    @id @default(cuid())
  eventId     String
  volunteerId String
  checkInAt   DateTime?
  createdAt   DateTime  @default(now())
  ngoId       String
  role        String?
  status      String?
  updatedAt   DateTime  @updatedAt

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([eventId, volunteerId])
  @@index([ngoId])
}

/// ---------- VOLUNTEER ----------
model Volunteer {
  id       String  @id @default(uuid())
  ngoId    String
  branchId String?

  // BASIC INFO
  name    String
  gender  String?
  dob     DateTime?
  phone   String?
  email   String?
  address String?
  avatar  String?

  // ROLE INFO
  volunteerType  String?
  skills         String[] @default([])
  areaOfInterest String?
  availability   String?

  // EMERGENCY CONTACT
  emergencyName  String?
  emergencyPhone String?

  // SYSTEM FIELDS
  joiningDate  DateTime? @default(now())
  status VolunteerStatus @default(NEW)
  totalHours   Int       @default(0)
  lastActivity DateTime?

  // NOTES
  notes String?

  // TIMESTAMPS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  ngo    NGO?    @relation(fields: [ngoId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  EventParticipant     EventParticipant[]
  VolunteerLog         VolunteerLog[]
  VolunteerBadge       VolunteerBadge[]
  VolunteerAchievement VolunteerAchievement[]
  VolunteerReport      VolunteerReport[]
  VolunteerActivity    VolunteerActivity[]

  @@index([ngoId])
  @@index([branchId])
}

/// ---------- TRUSTEES MANAGEMENT ----------
model Trustee {
  id         String        @id @default(cuid())
  ngoId      String

  name       String
  role       String
  email      String
  contact    String
  avatar     String?

  address    String?

  tenureFrom DateTime?
  tenureTo   DateTime?

  committees String[]      @default([])
  status     TrusteeStatus @default(ACTIVE)
  notes      String?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  ngo NGO @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
}

/// ---------- BOARD ACTIVITIES ----------
model BoardActivity {
  id           String         @id @default(cuid())
  ngoId        String
  type         String
  status       ActivityStatus @default(ONGOING)
  title        String
  place        String
  time         String
  participants String[]       @default([])
  extraText    String?
  cta          String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  ngo NGO @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
}

/// ---------- COMMUNICATION THREAD & MESSAGE ----------
model CommunicationThread {
  id        String        @id @default(cuid())
  ngoId     String
  subject   String?
  channel   ThreadChannel @default(INBOX)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  ngo      NGO                    @relation(fields: [ngoId], references: [id])
  messages CommunicationMessage[]

  @@index([ngoId])
}

model CommunicationMessage {
  id       String   @id @default(cuid())
  threadId String
  from     String
  to       String
  text     String
  time     DateTime @default(now())

  thread CommunicationThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
}

/// ---------- COMPLIANCE MODELS ----------
model Document {
  id        String   @id @default(cuid())
  title     String
  size      String
  updated   String?
  expires   String?
  icon      String
  type      String
  category  String
  userId    String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  text      String
  due       String
  status    String
  done      Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ComplianceActivity {
  id        String   @id @default(cuid())
  date      String
  text      String
  type      String
  userId    String
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// ---------- REPORTS ----------
model SavedReport {
  id       String    @id @default(cuid())
  ngoId    String
  name     String
  type     String
  config   Json
  cachedAt DateTime?
  cache    Json?

  ngo NGO @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
}

/// ---------- PASSWORD MANAGER ----------
model PasswordEntry {
  id        String         @id @default(cuid())
  ngoId     String
  title     String
  username  String
  url       String?
  notes     String?

  passwordEnc String
  encVersion  Int           @default(1)

  tags      String[]        @default([])
  status    PasswordStatus  @default(ACTIVE)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  ngo NGO @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
  @@index([ngoId, status])
  @@index([ngoId, title])
  @@unique([ngoId, title, username])
}

/// ---------- PLEDGES & REMINDERS ----------
model Pledge {
  id        String   @id @default(cuid())
  ngoId     String
  donorId   String
  amount    Decimal  @db.Decimal(12, 2)
  dueDate   DateTime
  note      String?
  status    String?  @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donor Donor @relation(fields: [donorId], references: [id])
  ngo   NGO   @relation(fields: [ngoId], references: [id])

  @@index([ngoId])
  @@index([donorId])
}

model Reminder {
  id        String   @id @default(cuid())
  ngoId     String
  donorId   String?
  pledgeId  String?
  sendAt    DateTime
  channel   String?
  payload   Json?
  createdAt DateTime @default(now())

  ngo     NGO?    @relation(fields: [ngoId], references: [id])
  donor   Donor?  @relation(fields: [donorId], references: [id])
  pledge  Pledge? @relation(fields: [pledgeId], references: [id])

  @@index([ngoId])
  @@index([donorId])
  @@index([pledgeId])
}

/// ---------- VOLUNTEER LOG / BADGE / ACHIEVEMENT / REPORT / ACTIVITY ----------
model VolunteerLog {
  id          String   @id @default(cuid())
  ngoId       String
  volunteerId String
  action      String
  details     String?
  loggedAt    DateTime @default(now())

  ngo       NGO       @relation(fields: [ngoId], references: [id])
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([ngoId])
  @@index([volunteerId])
}

model VolunteerBadge {
  id          String   @id @default(cuid())
  ngoId       String
  volunteerId String
  name        String
  description String?
  earnedAt    DateTime @default(now())

  ngo       NGO       @relation(fields: [ngoId], references: [id])
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([ngoId])
  @@index([volunteerId])
}

model VolunteerAchievement {
  id          String    @id @default(cuid())
  ngoId       String
  volunteerId String
  title       String
  description String?
  achievedAt  DateTime? @default(now())

  ngo       NGO       @relation(fields: [ngoId], references: [id])
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([ngoId])
  @@index([volunteerId])
}

model VolunteerReport {
  id          String    @id @default(cuid())
  ngoId       String
  volunteerId String
  periodFrom  DateTime?
  periodTo    DateTime?
  summary     Json?
  createdAt   DateTime  @default(now())

  ngo       NGO       @relation(fields: [ngoId], references: [id])
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([ngoId])
  @@index([volunteerId])
}

model VolunteerActivity {
  id           String   @id @default(cuid())
  ngoId        String
  volunteerId  String
  eventId      String?
  activity     String
  hours        Int      @default(0)
  activityDate DateTime @default(now())
  createdAt    DateTime @default(now())

  ngo       NGO       @relation(fields: [ngoId], references: [id])
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])
  event     Event?    @relation(fields: [eventId], references: [id])

  @@index([ngoId])
  @@index([volunteerId])
  @@index([eventId])
}

/// ---------- ENUMS ----------
enum BeneficiaryStatus {
  ACTIVE
  INACTIVE
  NEW
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventType {
  FUNDRAISER
  VOLUNTEER
  COMMUNITY
  EDUCATIONAL
  OTHER
}

enum VolunteerStatus {
  NEW
  ACTIVE
  INACTIVE
}

enum TrusteeStatus {
  ACTIVE
  INACTIVE
  NEW
}

enum ActivityStatus {
  ONGOING
  UPCOMING
  COMPLETED
}

enum ThreadChannel {
  INBOX
  SENT
  ANNOUNCEMENTS
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum DonationStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum PaymentMode {
  UPI
  CARD
  NETBANKING
  CHEQUE
  CASH
  BANK_TRANSFER
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PasswordStatus {
  ACTIVE
  ARCHIVED
}